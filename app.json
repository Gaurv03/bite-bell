{
  "expo": {
    "name": "bite-bells",
    "slug": "bite-bells",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bitebells",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.bitebells",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-audio",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff",
          "sounds": [
            "./assets/rings/mixkit_alert_alarm_1005.wav",
            "./assets/rings/mixkit_classic_alarm_995.wav",
            "./assets/rings/mixkit_crystal_chime_3108.wav",
            "./assets/rings/mixkit_facility_alarm_sound_999.wav",
            "./assets/rings/mixkit_interface_hint_notification_911.wav",
            "./assets/rings/mixkit_medium_size_crowd_applause_485.wav",
            "./assets/rings/mixkit_page_back_chime_1108.wav",
            "./assets/rings/mixkit_page_forward_single_chime_1107.wav",
            "./assets/rings/mixkit_race_countdown_1953.wav",
            "./assets/rings/mixkit_relaxing_bell_chime_3109.wav",
            "./assets/rings/mixkit_scanning_sci_fi_alarm_905.wav",
            "./assets/rings/mixkit_score_casino_counter_1998.wav",
            "./assets/rings/mixkit_slot_machine_payout_alarm_1996.wav",
            "./assets/rings/mixkit_slow_racing_countdown_1055.wav"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "db03a6f3-ec5c-43f6-9261-ad6956a5c4fa"
      }
    }
  }
}
